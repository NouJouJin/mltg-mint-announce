# Required
CONTRACT_ADDRESS=0x30961b851a8a766014e53955694b3210718066e5
POLYGON_RPC_URL=https://polygon-rpc.com
GAS_WEBHOOK_URL=https://script.google.com/macros/s/xxxxxxxxxxxxxxxxxxxxxxxxx/exec

# Optional
# If omitted, monitoring starts from the latest block.
START_BLOCK=

# Poll interval in milliseconds
# Default in current implementation: 15000 (15 seconds)
POLL_INTERVAL=15000

# GAS webhook timeout in milliseconds (applies to connection test and notifications)
GAS_TIMEOUT_MS=15000

# Maximum block range per eth_getLogs request (for RPC compatibility)
MAX_BLOCK_RANGE=1000
