# NFT Contract Address (Polygon)
CONTRACT_ADDRESS=0x30961b851a8a766014e53955694b3210718066e5

# Polygon RPC URL
# You can use public endpoints or services like Alchemy, Infura, QuickNode
# Public: https://polygon-rpc.com
# Alchemy: https://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY
POLYGON_RPC_URL=https://polygon-rpc.com

# Google Apps Script Web App URL
# Deploy your GAS as a web app and paste the URL here
GAS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR-DEPLOYMENT-ID/exec

# Optional: Block number to start monitoring from
# If not set, will start from the current block
# START_BLOCK=50000000

# Optional: Polling interval in milliseconds (default: 15000 = 15 seconds)
# Polygon block time is ~2 seconds, so 15 seconds is reasonable
# POLL_INTERVAL=15000
