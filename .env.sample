# NFT Contract Address (Polygon)
CONTRACT_ADDRESS=0xE828376750FA25a27D67ba7F5e9908ED85F9738B

# Polygon RPC URL
# You can use public endpoints or services like Alchemy, Infura, QuickNode
# Public: https://polygon-rpc.com
# Alchemy: https://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com/

# Google Apps Script Web App URL
# Deploy your GAS as a web app and paste the URL here
GAS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR-DEPLOYMENT-ID/exec

# Optional: Block number to start monitoring from
# If not set, will start from the current block
# Recommended: Set this to avoid missing past events on first run
# START_BLOCK=50000000

# Optional: Polling interval in milliseconds
#
# ⚡ Real-time monitoring (high cost):
#    POLL_INTERVAL=15000      # 15 seconds - 172,800 checks/month
#
# 💰 Cost-optimized (recommended for low-frequency mints):
#    POLL_INTERVAL=43200000    # 30 minutes - 1,440 checks/month (RECOMMENDED)
#    POLL_INTERVAL=3600000    # 1 hour - 720 checks/month
#
# For AWS deployment with infrequent mints (<1/day), 30-60 minutes is optimal
# The system will still catch all events, just with some delay
POLL_INTERVAL=43200000
